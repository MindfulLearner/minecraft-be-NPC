                    },
                    {
                        "name": "Ho visto cose peggiori.",
                        "commands": ["/dialogue open @e[tag=cacciatrice,r=10] @initiator cacciatrice_sfida"]
                    },
                    {
                        "name": "Dimmi le missioni.",
                        "commands": ["/dialogue open @e[tag=cacciatrice,r=10] @initiator cacciatrice_main"]
                    }
                ]
            },
            {
                "scene_tag": "cacciatrice_sfida",
                "npc_name": "§6Elena",
                "text": "§f— Interessante.\n§7Chi parla così di solito scappa al primo creeper.\n§fDimostramelo sul campo. Scegli una preda.",
