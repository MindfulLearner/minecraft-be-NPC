                    {
                        "name": "Sono pronto.",
                        "commands": ["/dialogue open @e[tag=cacciatrice,r=10] @initiator cacciatrice_main"]
                    }
                ]
            },
            {
                "scene_tag": "cacciatrice_main",
                "npc_name": "§6Elena",
                "text": "§fScegli la preda. Torna con le prove.\n§7Non mi interessano le scuse.",
