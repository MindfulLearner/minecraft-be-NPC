{
    "format_version": "1.17",
    "minecraft:npc_dialogue": {
        "scenes": [
            {
                "scene_tag": "costruttore_intro",
                "npc_name": "§9Marco",
                "text": "§aUn momento! Sto disegnando qualcosa.\n§2Guarda — questo villaggio può essere enorme.\n§aHo solo bisogno di materiali.",
                "buttons": [
                    {
                        "name": "Dimmi il piano.",
                        "commands": ["/dialogue open @e[tag=costruttore,r=2] @initiator costruttore_sogno"]
                    },
                    {
                        "name": "Posso aiutare.",
                        "commands": ["/dialogue open @e[tag=costruttore,r=2] @initiator costruttore_main"]
                    }
                ]
            },
            {
                "scene_tag": "costruttore_sogno",
                "npc_name": "§9Marco",
                "text": "§aUna torre al centro. Case per tutti.\n§2Strade lastricate, lanterne ovunque.\n§aSenza materiali non si costruisce nulla.",
                "buttons": [
                    {
                        "name": "Ci penso io.",
                        "commands": ["/dialogue open @e[tag=costruttore,r=2] @initiator costruttore_main"]
                    },
                    {
                        "name": "Bel sogno...",
                        "commands": ["/dialogue open @e[tag=costruttore,r=2] @initiator costruttore_realista"]
                    }
                ]
            },
            {
                "scene_tag": "costruttore_realista",
                "npc_name": "§9Marco",
                "text": "§a— Sogno?\n§2È un piano architettonico dettagliato.\n§a...Ok, forse è un sogno. Aiutami lo stesso.",
                "buttons": [
                    {
                        "name": "Ci sto.",
                        "commands": ["/dialogue open @e[tag=costruttore,r=2] @initiator costruttore_main"]
                    }
                ]
            },
            {
                "scene_tag": "costruttore_main",
                "npc_name": "§9Marco",
                "text": "§aMateriali, materiali, materiali.\n§2Scegli una consegna o porta ciò che hai.",
                "buttons": [
                    {
                        "name": "64 Ciottoli",
                        "commands": ["/scriptevent costruttore:accept marco_ciottoli"]
                    },
                    {
                        "name": "32 Tronchi",
                        "commands": ["/scriptevent costruttore:accept marco_quercia"]
                    },
                    {
                        "name": "16 Carbone",
                        "commands": ["/scriptevent costruttore:accept marco_carbone"]
                    },
                    {
                        "name": "32 Ghiaia",
                        "commands": ["/scriptevent costruttore:accept marco_ghiaia"]
                    },
                    {
                        "name": "§a» Consegna",
                        "commands": ["/dialogue open @e[tag=costruttore,r=2] @initiator costruttore_consegna"]
                    }
                ]
            },
            {
                "scene_tag": "costruttore_consegna",
                "npc_name": "§9Marco",
                "text": "§aHai il materiale?\n§2Ogni blocco è un mattone verso il futuro.",
                "buttons": [
                    {
                        "name": "64 Ciottoli",
                        "commands": ["/scriptevent costruttore:deliver marco_ciottoli"]
                    },
                    {
                        "name": "32 Tronchi",
                        "commands": ["/scriptevent costruttore:deliver marco_quercia"]
                    },
                    {
                        "name": "16 Carbone",
                        "commands": ["/scriptevent costruttore:deliver marco_carbone"]
                    },
                    {
                        "name": "32 Ghiaia",
                        "commands": ["/scriptevent costruttore:deliver marco_ghiaia"]
                    },
                    {
                        "name": "§2« Indietro",
                        "commands": ["/dialogue open @e[tag=costruttore,r=2] @initiator costruttore_main"]
                    }
                ]
            }
        ]
    }
}
