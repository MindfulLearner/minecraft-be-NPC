{
    "format_version": "1.17",
    "minecraft:npc_dialogue": {
        "scenes": [
            {
                "scene_tag": "pescatore_intro",
                "npc_name": "§bOld Piero",
                "text": "§3...\n§bVattene. L'acqua porta via tutto.\n§3Non voglio aiuto da nessuno.",
                "buttons": [
                    {
                        "name": "Cos'è successo?",
                        "commands": ["/dialogue open @e[tag=pescatore,r=2] @initiator pescatore_storia"]
                    },
                    {
                        "name": "Ho bisogno di te.",
                        "commands": ["/dialogue open @e[tag=pescatore,r=2] @initiator pescatore_main"]
                    }
                ]
            },
            {
                "scene_tag": "pescatore_storia",
                "npc_name": "§bOld Piero",
                "text": "§bEravamo sulla barca. Io, Anna, i bambini.\n§3Una cosa enorme è salita dal fondo.\n§bNon ho potuto fare nulla. Nulla.",
                "buttons": [
                    {
                        "name": "Li vendicherò.",
                        "commands": ["/dialogue open @e[tag=pescatore,r=2] @initiator pescatore_patto"]
                    },
                    {
                        "name": "Mi dispiace...",
                        "commands": ["/dialogue open @e[tag=pescatore,r=2] @initiator pescatore_patto"]
                    }
                ]
            },
            {
                "scene_tag": "pescatore_patto",
                "npc_name": "§bOld Piero",
                "text": "§bDavvero? Non posso più toccare una canna.\n§3Ma tu puoi. Pesca per me.\n§bOgni pesce è un passo verso la vendetta.",
                "buttons": [
                    {
                        "name": "Capito.",
                        "commands": ["/dialogue open @e[tag=pescatore,r=2] @initiator pescatore_main"]
                    }
                ]
            },
            {
                "scene_tag": "pescatore_main",
                "npc_name": "§bOld Piero",
                "text": "§bHo paura. Ma tu no.\n§3Pesca per me. Ti pago in pepite.\n§bScegli una missione, o consegna.",
                "buttons": [
                    {
                        "name": "10 Merluzzi",
                        "commands": ["/scriptevent pescatore:accept piero_pesce"]
                    },
                    {
                        "name": "8 Salmoni",
                        "commands": ["/scriptevent pescatore:accept piero_salmone"]
                    },
                    {
                        "name": "6 Tropicali",
                        "commands": ["/scriptevent pescatore:accept piero_tropicale"]
                    },
                    {
                        "name": "§a» Consegna",
                        "commands": ["/dialogue open @e[tag=pescatore,r=2] @initiator pescatore_consegna"]
                    }
                ]
            },
            {
                "scene_tag": "pescatore_consegna",
                "npc_name": "§bOld Piero",
                "text": "§bHai portato i pesci?\n§3Ogni pesce è... giustizia.",
                "buttons": [
                    {
                        "name": "10 Merluzzi",
                        "commands": ["/scriptevent pescatore:deliver piero_pesce"]
                    },
                    {
                        "name": "8 Salmoni",
                        "commands": ["/scriptevent pescatore:deliver piero_salmone"]
                    },
                    {
                        "name": "6 Tropicali",
                        "commands": ["/scriptevent pescatore:deliver piero_tropicale"]
                    },
                    {
                        "name": "§3« Indietro",
                        "commands": ["/dialogue open @e[tag=pescatore,r=2] @initiator pescatore_main"]
                    }
                ]
            }
        ]
    }
}
